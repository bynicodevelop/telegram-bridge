# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (get it from @userinfobot)
TELEGRAM_OWNER_ID=

# Claude CLI path (default: claude)
# CLAUDE_PATH=claude

# Timeout for Claude executions in ms (default: 300000 = 5min)
# CLAUDE_TIMEOUT_MS=300000

# Directory containing your projects (default: ~/projects)
# PROJECTS_DIR=/home/user/projects

# Directory of telegram-bridge itself (default: process.cwd())
# BRIDGE_DIR=/home/user/telegram-bridge

# Directory for global memory files (default: $PROJECTS_DIR/.provider/memory)
# MEMORY_DIR=
